# Cluster naming
CLUSTER_PREFIX=lab-k8s
MASTER_VM_NAME=lab-k8s-master
MASTER_HOSTNAME=lab-k8s-master

# Base image and resources
VM_BOX=bento/ubuntu-24.04
VM_CPUS=4
VM_MEMORY_MB=8192
VM_BOOT_TIMEOUT=600
WORKER_COUNT=2

# Networking
PRIVATE_NETWORK_PREFIX=192.168.56
PRIVATE_NETWORK_GATEWAY=192.168.56.1
MASTER_PRIVATE_IP=192.168.56.10
MASTER_SSH_PORT=2232
MASTER_API_PORT=6443
MASTER_DASHBOARD_PORT=30443

WORKER1_VM_NAME=lab-k8s-worker1
WORKER1_HOSTNAME=lab-k8s-worker1
WORKER1_PRIVATE_IP=192.168.56.11
WORKER1_SSH_PORT=2242

WORKER2_VM_NAME=lab-k8s-worker2
WORKER2_HOSTNAME=lab-k8s-worker2
WORKER2_PRIVATE_IP=192.168.56.12
WORKER2_SSH_PORT=2252

# Optional bridged adapter in VirtualBox.
# Leave empty for private_network only.
BRIDGE_ADAPTER=

# Kubernetes settings
KUBERNETES_VERSION=1.34
POD_CIDR=10.244.0.0/16
