# =============================================================================
# .env.example — Шаблон конфигурации (Stage 2: Production-Ready)
# =============================================================================
#
# КАК ИСПОЛЬЗОВАТЬ:
#   Скопируй этот файл в .env и отредактируй под свои нужды:
#     Windows: copy .env.example .env
#     Linux/Mac: cp .env.example .env
#
#   .env НЕ коммитится в git (он в .gitignore) — у каждого разработчика
#   своя копия с локальными настройками.
#
# АВТОМАТИЧЕСКАЯ ГЕНЕРАЦИЯ:
#   Если запускаешь через NSIS-визард или proxy-launch.bat — .env
#   создаётся автоматически из твоих ответов на вопросы.
#
# СИНТАКСИС:
#   КЛЮЧ=значение
#   # Комментарий (строка начинается с #)
#   Пробелы вокруг = — не допускаются: KEY=VALUE (не KEY = VALUE)
# =============================================================================

# =============================================================================
# ИМЕНОВАНИЕ КЛАСТЕРА
# =============================================================================
# CLUSTER_PREFIX — общий префикс для всех имён ВМ и хостов.
# Используется как основа для MASTER_VM_NAME, WORKER*_VM_NAME.
# Допускаются буквы, цифры, дефисы. Не должен начинаться с цифры.
# Пример: "mylab" → ВМ будут называться mylab-master, mylab-worker1, ...
CLUSTER_PREFIX=lab-k8s

# Полное имя ВМ мастера в VirtualBox (уникально в рамках твоего VirtualBox).
MASTER_VM_NAME=lab-k8s-master

# Hostname внутри ОС мастер-ноды.
# Kubernetes идентифицирует ноду по этому имени (kubectl get nodes).
# Должен совпадать с DNS-именем в /etc/hosts всех нод.
MASTER_HOSTNAME=lab-k8s-master

# =============================================================================
# ОБРАЗ И РЕСУРСЫ
# =============================================================================
# VM_BOX — базовый образ Vagrant.
# Список доступных образов: https://app.vagrantup.com/boxes/search
# Рекомендуется: bento/ubuntu-24.04 (Ubuntu 24.04 LTS Noble Numbat)
# Альтернатива: ubuntu/jammy64 (официальный, медленнее)
VM_BOX=bento/ubuntu-24.04

# Количество виртуальных процессорных ядер на каждую ВМ.
# Минимум для мастера: 2 (kubeadm требует). Для воркеров: 1 допустимо.
# Рекомендуется: 2 при 8 ГБ RAM на хосте, 4 при 16 ГБ+.
VM_CPUS=2

# Оперативная память в мегабайтах на каждую ВМ.
# Минимум: 1700 MB (мастер), 512 MB (воркер — хватит для тестов).
# Рекомендуется: 2048 MB (2 ГБ) на каждую ноду.
# При 3 нодах × 2048 = 6 ГБ будет занято на хосте.
VM_MEMORY_MB=2048

# Таймаут запуска ВМ в секундах.
# 600 = 10 минут. Если первый запуск долгий (медленный диск) — увеличь.
VM_BOOT_TIMEOUT=600

# Количество рабочих нод (workers). Диапазон: 1–4.
# При WORKER_COUNT=1 будет 1 master + 1 worker = минимальный кластер.
# При WORKER_COUNT=2 (default) — стандартный учебный кластер.
WORKER_COUNT=2

# =============================================================================
# СЕТЬ
# =============================================================================
# PRIVATE_NETWORK_PREFIX — первые три октета подсети host-only адаптера.
# Vagrant создаёт виртуальную сеть VirtualBox: 192.168.56.0/24
# В этой сети ноды видят друг друга и Windows-хост.
#
# ВАЖНО: не пересекаться с домашней сетью (обычно 192.168.0.x или 192.168.1.x)
# и не конфликтовать с другими Vagrant-проектами.
PRIVATE_NETWORK_PREFIX=192.168.56

# IP-адрес шлюза в host-only сети (первый адрес — сам VirtualBox).
PRIVATE_NETWORK_GATEWAY=192.168.56.1

# Фиксированный IP master-ноды в host-only сети.
# На этот адрес настраивается --apiserver-advertise-address в kubeadm init.
# Воркеры подключаются к мастеру по этому IP.
MASTER_PRIVATE_IP=192.168.56.10

# Порт на хосте Windows, проброшенный на порт 22 (SSH) мастера.
# Пример: ssh vagrant@127.0.0.1 -p 2232 (или vagrant ssh lab-k8s-master)
MASTER_SSH_PORT=2232

# Порт для Kubernetes API Server.
# Пример с хоста: kubectl --server=https://127.0.0.1:6443
MASTER_API_PORT=6443

# Порт для Kubernetes Dashboard (NodePort).
# Открывай в браузере: https://localhost:30443
MASTER_DASHBOARD_PORT=30443

# --- Воркер 1 ---
WORKER1_VM_NAME=lab-k8s-worker1
WORKER1_HOSTNAME=lab-k8s-worker1
WORKER1_PRIVATE_IP=192.168.56.11
WORKER1_SSH_PORT=2242

# --- Воркер 2 ---
WORKER2_VM_NAME=lab-k8s-worker2
WORKER2_HOSTNAME=lab-k8s-worker2
WORKER2_PRIVATE_IP=192.168.56.12
WORKER2_SSH_PORT=2252

# --- Воркеры 3 и 4 (для WORKER_COUNT=3 или 4) ---
# Раскомментируй если WORKER_COUNT > 2
# WORKER3_VM_NAME=lab-k8s-worker3
# WORKER3_HOSTNAME=lab-k8s-worker3
# WORKER3_PRIVATE_IP=192.168.56.13
# WORKER3_SSH_PORT=2262
#
# WORKER4_VM_NAME=lab-k8s-worker4
# WORKER4_HOSTNAME=lab-k8s-worker4
# WORKER4_PRIVATE_IP=192.168.56.14
# WORKER4_SSH_PORT=2272

# --- Bridged (сетевой мост) — опционально ---
# Если заполнено — добавляется третий сетевой адаптер в ВМ.
# Это даёт прямой доступ к ВМ из домашней сети (например, с телефона).
# Узнать имя адаптера: VBoxManage list bridgedifs
# Пример: BRIDGE_ADAPTER=Intel(R) Wi-Fi 6 AX200 160MHz
# Оставь пустым для стандартной (более изолированной) конфигурации.
BRIDGE_ADAPTER=

# =============================================================================
# KUBERNETES
# =============================================================================
# Версия Kubernetes для установки (без 'v', только мажор.минор).
# Используется при формировании URL репозитория pkgs.k8s.io.
# Пример: 1.34 → https://pkgs.k8s.io/core:/stable:/v1.34/deb/
#
# ВАЖНО: все ноды должны использовать одну и ту же версию.
# Обновление версии — отдельный процесс (kubeadm upgrade), не через .env.
KUBERNETES_VERSION=1.34

# Диапазон IP-адресов для Pod-сети (Pod CIDR).
# Calico CNI разобьёт этот диапазон по /26 на каждую ноду.
# 10.244.0.0/16 = 65536 адресов — стандарт для Calico/Flannel в lab.
# НЕ должен пересекаться с PRIVATE_NETWORK_PREFIX и домашней сетью.
POD_CIDR=10.244.0.0/16
