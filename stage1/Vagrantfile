#
#  Windows (хост)
#  ├── VirtualBox Host-Only Network (192.168.56.0/24)
#  │   ├── k8s-master   192.168.56.10   ← управление кластером
#  │   ├── k8s-worker1  192.168.56.11   ← рабочая нода
#  │   └── k8s-worker2  192.168.56.12   ← рабочая нода
#  │
#  └── Порты на localhost (127.0.0.1):
#      ├── :2232 → master SSH
#      ├── :6443 → Kubernetes API
#      └── :30443 → Dashboard HTTPS
